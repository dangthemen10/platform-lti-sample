# .env.local.example
# ============================================================
# ĐÚNG VAI TRÒ: Education Hub = Platform (LMS)
# Các biến này cấu hình Education Hub để kết nối với
# Microsoft LTI Gateway với tư cách là một Platform.
# ============================================================

# ── MONGODB ─────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/education_hub

# ── RSA KEY CỦA EDUCATION HUB (PLATFORM) ────────────────────
# Education Hub dùng key này để:
#   1. Ký các JWT request gửi đến MS LTI Gateway
#   2. Expose Public Key qua /api/lti/keys để Gateway verify
# Tạo bằng: npm run generate-keys
LTI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----"
LTI_KEY_ID=education-hub-platform-key-1

# ── THÔNG TIN ĐĂNG KÝ PLATFORM TRÊN MS LTI GATEWAY ─────────
# Sau khi đăng ký Education Hub làm Platform trên Gateway,
# Microsoft sẽ cấp Client ID này.
# Điền vào đây VÀ vào collection lti_registrations trong MongoDB.
LTI_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Issuer của Microsoft LTI Gateway (không phải Azure AD)
LTI_ISSUER=https://lti.microsoft.com

# ── URL CỦA EDUCATION HUB ───────────────────────────────────
# URL này phải đăng ký trên MS LTI Gateway Admin Portal:
#   Platform Login URL     : https://your-app.vercel.app/api/lti/launch
#   Platform Redirect URL  : https://your-app.vercel.app/api/lti/callback
#   Platform Keyset URL    : https://your-app.vercel.app/api/lti/keys
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── SESSION ─────────────────────────────────────────────────
# Secret để ký session JWT nội bộ của Education Hub
# Tạo bằng: openssl rand -base64 32
SESSION_SECRET=your-random-secret-here

# ── NODE ENV ─────────────────────────────────────────────────
NODE_ENV=development
